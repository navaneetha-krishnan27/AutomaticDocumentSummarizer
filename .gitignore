# ---------------------------------------------------
# 1. SECURITY (Never upload these!)
# ---------------------------------------------------
.env
*.pem
*.key

# ---------------------------------------------------
# 2. VIRTUAL ENVIRONMENTS (Too large to upload)
# ---------------------------------------------------
venv/
.venv/
env/
ENV/

# ---------------------------------------------------
# 3. PYTHON CACHE (Useless system files)
# ---------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ---------------------------------------------------
# 4. FLASK SPECIFIC
# ---------------------------------------------------
instance/
.webassets-cache

# ---------------------------------------------------
# 5. PROJECT SPECIFIC (AI Summarizer Data)
# ---------------------------------------------------
# Ignore user uploaded documents and generated PDFs
uploads/
*.pdf
*.docx
*.pptx

# Ignore the heavy locally downloaded AI models
local_ml_model/

# ---------------------------------------------------
# 6. LOGS & LOCAL DATABASES
# ---------------------------------------------------
*.log
*.sqlite3
*.db

# ---------------------------------------------------
# 7. IDE & OS FILES
# ---------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
